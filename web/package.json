{
  "name": "clover-web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "predev": "tsx scripts/sync-public-assets.ts",
    "dev": "next dev",
    "prebuild": "tsx scripts/sync-public-assets.ts && node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "tsx scripts/sync-public-assets.ts && prisma generate",
    "worker:imports": "tsx workers/imports-worker.ts",
    "db:seed": "tsx prisma/seed.ts",
    "qa:parsers": "tsx scripts/parser-regression.ts",
    "qa:imports": "tsx scripts/import-smoke-regression.ts",
    "qa:training-signals": "tsx scripts/training-signal-dedupe.ts",
    "qa:training-signals-db": "tsx scripts/record-training-signal-regression.ts",
    "qa:data-loop": "tsx scripts/data-qa-regression.ts",
    "train:image-labels": "tsx --tsconfig tsconfig.json scripts/train-image-label-corpus.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.844.0",
    "@aws-sdk/s3-request-presigner": "^3.844.0",
    "@clerk/nextjs": "^6.30.1",
    "@napi-rs/canvas": "^0.1.100",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bullmq": "^5.74.1",
    "ioredis": "^5.10.1",
    "jszip": "^3.10.1",
    "next": "^15.5.0",
    "pdfjs-dist": "^5.6.205",
    "pdfjs-serverless": "^1.2.2",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.21.0",
    "zod": "^4.1.11"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "typescript": "^5.9.2"
  }
}
