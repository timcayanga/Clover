generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceType {
  personal
  shared
  business
}

enum AccountType {
  bank
  wallet
  credit_card
  cash
  investment
  other
}

enum TransactionType {
  income
  expense
  transfer
}

enum ReviewStatus {
  pending_review
  suggested
  confirmed
  edited
  rejected
  duplicate_skipped
}

enum ImportFileStatus {
  processing
  done
  failed
  deleted
}

enum StatementCheckpointStatus {
  pending
  reconciled
  mismatch
}

enum TrainingSignalSource {
  import_confirmation
  manual_recategorization
  training_upload
  manual_transaction_creation
}

enum PlanTier {
  free
  pro
}

enum BillingProvider {
  paypal
}

enum BillingInterval {
  monthly
  annual
}

enum BillingSubscriptionStatus {
  approval_pending
  active
  cancelled
  suspended
  expired
  unknown
}

enum FinancialExperienceLevel {
  beginner
  comfortable
  advanced
}

model User {
  id                    String                    @id @default(cuid())
  clerkUserId           String                    @unique
  email                 String                    @unique
  firstName             String?
  lastName              String?
  verified              Boolean                   @default(false)
  environment           String                    @default("production")
  planTier              PlanTier                  @default(free)
  planTierLocked        Boolean                   @default(false)
  accountLimit          Int?
  monthlyUploadLimit    Int?
  transactionLimit      Int?
  financialExperience   FinancialExperienceLevel? @default(beginner)
  primaryGoal           String?
  goalTargetAmount      Decimal?                  @db.Decimal(18, 2)
  goalTargetSource      String?
  goalPlan              Json?
  onboardingCompletedAt DateTime?
  dataWipedAt           DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  workspaces            Workspace[]
  goalSettings          GoalSetting[]
  billingSubscription   BillingSubscription?
  billingEvents         BillingEvent[]
  appErrorLogs          AppErrorLog[]
}

model BillingSubscription {
  id                     String                    @id @default(cuid())
  userId                 String                    @unique
  provider               BillingProvider           @default(paypal)
  providerSubscriptionId String?                   @unique
  providerPlanId         String?
  status                 BillingSubscriptionStatus @default(unknown)
  planTier               PlanTier                  @default(free)
  interval               BillingInterval?
  pendingPlanId          String?
  pendingInterval        BillingInterval?
  currentPeriodEnd       DateTime?
  nextBillingTime        DateTime?
  cancelledAt            DateTime?
  approvedAt             DateTime?
  lastEventType          String?
  lastSyncedAt           DateTime?
  rawPayload             Json?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  user                   User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([providerSubscriptionId])
  @@index([providerPlanId])
  @@index([status])
}

model BillingEvent {
  id              String          @id @default(cuid())
  provider        BillingProvider @default(paypal)
  providerEventId String?         @unique
  eventType       String
  subscriptionId  String?
  userId          String?
  status          String?
  rawPayload      Json
  processedAt     DateTime?
  createdAt       DateTime        @default(now())
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@index([userId])
  @@index([eventType])
}

model AppErrorLog {
  id            String    @id @default(cuid())
  message       String
  name          String?
  stack         String?
  source        String
  route         String?
  url           String?
  method        String?
  statusCode    Int?
  buildId       String
  deploymentId  String?
  environment   String
  userAgent     String?
  clerkUserId   String?
  userId        String?
  workspaceId   String?
  metadata      Json?
  occurredAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([buildId])
  @@index([environment])
  @@index([source])
  @@index([userId])
}

model Workspace {
  id                   String                       @id @default(cuid())
  userId               String
  name                 String
  type                 WorkspaceType                @default(personal)
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  user                 User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts             Account[]
  categories           Category[]
  transactions         Transaction[]
  importFiles          ImportFile[]
  statementCheckpoints AccountStatementCheckpoint[]
  auditLogs            AuditLog[]
  statementTemplates   StatementTemplate[]
  merchantRules        MerchantRule[]
  accountRules         AccountRule[]
  trainingSignals      TrainingSignal[]
  dataQaRuns           DataQaRun[]
  dataQaFindings       DataQaFinding[]

  @@index([userId])
}

model Account {
  id                     String        @id @default(cuid())
  workspaceId            String
  name                   String
  institution            String?
  investmentSubtype      String?
  investmentSymbol       String?
  investmentQuantity     Decimal?      @db.Decimal(18, 8)
  investmentCostBasis    Decimal?      @db.Decimal(18, 2)
  investmentPrincipal    Decimal?      @db.Decimal(18, 2)
  investmentStartDate    DateTime?
  investmentMaturityDate DateTime?
  investmentInterestRate Decimal?      @db.Decimal(9, 4)
  investmentMaturityValue Decimal?     @db.Decimal(18, 2)
  type                   AccountType   @default(bank)
  currency               String        @default("PHP")
  source                 String        @default("upload")
  balance                Decimal?      @db.Decimal(18, 2)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  workspace              Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions           Transaction[]
  importFiles            ImportFile[]
  statementCheckpoints   AccountStatementCheckpoint[]
  accountRules           AccountRule[]

  @@index([workspaceId])
}

model Category {
  id               String           @id @default(cuid())
  workspaceId      String
  name             String
  type             TransactionType
  parentCategoryId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  trainingSignals  TrainingSignal[]
  merchantRules    MerchantRule[]

  @@index([workspaceId])
}

model Transaction {
  id                     String           @id @default(cuid())
  workspaceId            String
  accountId              String
  importFileId           String?
  categoryId             String?
  reviewStatus           ReviewStatus     @default(suggested)
  parserConfidence       Int              @default(0)
  categoryConfidence     Int              @default(0)
  accountMatchConfidence Int              @default(0)
  duplicateConfidence    Int              @default(0)
  transferConfidence     Int              @default(0)
  rawPayload             Json?
  normalizedPayload      Json?
  learnedRuleIdsApplied  Json?
  date                   DateTime
  amount                 Decimal          @db.Decimal(18, 2)
  currency               String           @default("PHP")
  type                   TransactionType
  merchantRaw            String
  merchantClean          String?
  description            String?
  isTransfer             Boolean          @default(false)
  isExcluded             Boolean          @default(false)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  workspace              Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account                Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  importFile             ImportFile?      @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  category               Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  trainingSignals        TrainingSignal[]
  dataQaFindings         DataQaFinding[]

  @@index([workspaceId])
  @@index([accountId])
  @@index([importFileId])
  @@index([categoryId])
  @@index([reviewStatus])
  @@index([date])
}

model ImportFile {
  id                         String                      @id @default(cuid())
  workspaceId                String
  accountId                  String?
  fileName                   String
  fileType                   String
  storageKey                 String
  status                     ImportFileStatus            @default(processing)
  processingPhase            String?
  processingMessage          String?
  processingAttempt          Int                         @default(0)
  processingTargetScore      Int?
  processingCurrentScore     Int?
  parsedRowsCount            Int                         @default(0)
  confirmedTransactionsCount Int                         @default(0)
  confirmedAt                DateTime?
  uploadedAt                 DateTime                    @default(now())
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  workspace                  Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account                    Account?                    @relation(fields: [accountId], references: [id], onDelete: SetNull)
  parsedRows                 ParsedTransaction[]
  transactions               Transaction[]
  trainingSignals            TrainingSignal[]
  statementCheckpoint        AccountStatementCheckpoint?
  dataQaRuns                 DataQaRun[]
  dataQaFindings             DataQaFinding[]

  @@index([workspaceId])
  @@index([accountId])
  @@index([status])
}

model AccountStatementCheckpoint {
  id                 String                    @id @default(cuid())
  workspaceId        String
  accountId          String?
  importFileId       String?                   @unique
  statementStartDate DateTime?
  statementEndDate   DateTime?
  openingBalance     Decimal?                  @db.Decimal(18, 2)
  endingBalance      Decimal?                  @db.Decimal(18, 2)
  status             StatementCheckpointStatus @default(pending)
  mismatchReason     String?
  sourceMetadata     Json?
  rowCount           Int                       @default(0)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  workspace          Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account            Account?                  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  importFile         ImportFile?               @relation(fields: [importFileId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([accountId])
  @@index([importFileId])
  @@index([statementStartDate])
  @@index([statementEndDate])
  @@index([status])
}

model ParsedTransaction {
  id                   String           @id @default(cuid())
  importFileId         String
  workspaceId          String
  institution          String?
  accountNumber        String?
  accountName          String?
  date                 DateTime?
  amount               Decimal?         @db.Decimal(18, 2)
  merchantRaw          String?
  merchantClean        String?
  type                 TransactionType?
  categoryName         String?
  confidence           Int              @default(0)
  categoryReason       String?
  parserVersion        String           @default("v1")
  statementFingerprint String?
  rawPayload           Json?
  createdAt            DateTime         @default(now())
  importFile           ImportFile       @relation(fields: [importFileId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([importFileId])
  @@index([statementFingerprint])
}

model StatementTemplate {
  id            String    @id @default(cuid())
  workspaceId   String
  fingerprint   String
  fileType      String?
  institution   String?
  accountNumber String?
  accountName   String?
  parserVersion String    @default("v1")
  parserConfig  Json?
  exampleCount  Int       @default(1)
  successCount  Int       @default(1)
  failureCount  Int       @default(0)
  lastSeenAt    DateTime  @default(now())
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, fingerprint])
  @@index([workspaceId])
}

model GoalSetting {
  id           String   @id @default(cuid())
  userId       String
  primaryGoal  String?
  targetAmount Decimal? @db.Decimal(18, 2)
  source       String?
  goalPlan     Json?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model DataQaConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  body      String   @db.Text
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model MerchantRule {
  id              String    @id @default(cuid())
  workspaceId     String
  merchantKey     String
  merchantPattern String?
  normalizedName  String
  categoryId      String?
  categoryName    String?
  source          String    @default("manual")
  confidence      Int       @default(100)
  timesConfirmed  Int       @default(1)
  lastUsedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, merchantKey])
  @@index([workspaceId])
  @@index([merchantKey])
}

model AccountRule {
  id             String      @id @default(cuid())
  workspaceId    String
  accountId      String?
  ruleKey        String
  accountName    String
  institution    String?
  accountType    AccountType
  source         String      @default("manual")
  confidence     Int         @default(100)
  timesConfirmed Int         @default(1)
  lastUsedAt     DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  workspace      Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account        Account?    @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, ruleKey])
  @@index([workspaceId])
  @@index([accountId])
  @@index([ruleKey])
}

model TrainingSignal {
  id             String               @id @default(cuid())
  workspaceId    String
  transactionId  String?
  importFileId   String?
  source         TrainingSignalSource
  merchantKey    String
  dedupeKey      String
  merchantTokens Json?
  categoryId     String
  categoryName   String?
  type           TransactionType
  confidence     Int                  @default(100)
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transaction    Transaction?         @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  importFile     ImportFile?          @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  category       Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, dedupeKey])
  @@index([workspaceId])
  @@index([transactionId])
  @@index([importFileId])
  @@index([merchantKey])
}

model DataQaRun {
  id                String         @id @default(cuid())
  workspaceId       String
  importFileId      String?
  source            String
  stage             String?
  status            String         @default("completed")
  parserVersion     String?
  parserDurationMs  Int?
  totalDurationMs   Int?
  score             Int            @default(0)
  findingCount      Int            @default(0)
  criticalCount     Int            @default(0)
  feedbackPayload   Json?
  manualFeedback    String?
  manualFeedbackUpdatedAt DateTime?
  manualFeedbackAuthorId  String?
  fieldReviewPayload Json?
  fieldReviewUpdatedAt DateTime?
  fieldReviewAuthorId String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  workspace         Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importFile        ImportFile?    @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  findings          DataQaFinding[]

  @@index([workspaceId])
  @@index([importFileId])
  @@index([source])
  @@index([status])
}

model DataQaFinding {
  id              String      @id @default(cuid())
  workspaceId     String
  dataQaRunId     String
  importFileId    String?
  transactionId   String?
  code            String
  severity        String
  field           String?
  message         String
  observedValue   Json?
  expectedValue   Json?
  suggestion      String?
  confidence      Int         @default(0)
  metadata        Json?
  createdAt       DateTime    @default(now())
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dataQaRun       DataQaRun   @relation(fields: [dataQaRunId], references: [id], onDelete: Cascade)
  importFile      ImportFile? @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  transaction     Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([dataQaRunId])
  @@index([importFileId])
  @@index([transactionId])
  @@index([code])
  @@index([severity])
}

model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  actorUserId String
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([actorUserId])
}
