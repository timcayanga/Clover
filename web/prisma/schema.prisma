generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceType {
  personal
  shared
  business
}

enum AccountType {
  bank
  wallet
  credit_card
  cash
  investment
  other
}

enum TransactionType {
  income
  expense
  transfer
}

enum ReviewStatus {
  pending_review
  suggested
  confirmed
  edited
  rejected
  duplicate_skipped
}

enum ImportFileStatus {
  processing
  done
  failed
  deleted
}

enum StatementCheckpointStatus {
  pending
  reconciled
  mismatch
}

enum TrainingSignalSource {
  import_confirmation
  manual_recategorization
  training_upload
  manual_transaction_creation
}

enum PlanTier {
  free
  pro
}

enum FinancialExperienceLevel {
  beginner
  comfortable
  advanced
}

model User {
  id                    String      @id @default(cuid())
  clerkUserId           String      @unique
  email                 String      @unique
  verified              Boolean     @default(false)
  planTier              PlanTier    @default(free)
  financialExperience   FinancialExperienceLevel? @default(beginner)
  primaryGoal           String?
  goalTargetAmount      Decimal?    @db.Decimal(18, 2)
  goalTargetSource      String?
  onboardingCompletedAt DateTime?
  dataWipedAt           DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  workspaces            Workspace[]
  goalSettings          GoalSetting[]
}

model Workspace {
  id            String        @id @default(cuid())
  userId        String
  name          String
  type          WorkspaceType @default(personal)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts      Account[]
  categories    Category[]
  transactions  Transaction[]
  importFiles   ImportFile[]
  statementCheckpoints AccountStatementCheckpoint[]
  auditLogs     AuditLog[]
  statementTemplates StatementTemplate[]
  merchantRules MerchantRule[]
  accountRules  AccountRule[]
  trainingSignals TrainingSignal[]

  @@index([userId])
}

model Account {
  id            String        @id @default(cuid())
  workspaceId   String
  name          String
  institution   String?
  type          AccountType   @default(bank)
  currency      String        @default("PHP")
  source        String        @default("upload")
  balance       Decimal?      @db.Decimal(18, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  importFiles   ImportFile[]
  statementCheckpoints AccountStatementCheckpoint[]
  accountRules  AccountRule[]

  @@index([workspaceId])
}

model Category {
  id               String      @id @default(cuid())
  workspaceId      String
  name             String
  type             TransactionType
  parentCategoryId String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  workspace        Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  trainingSignals  TrainingSignal[]
  merchantRules    MerchantRule[]

  @@index([workspaceId])
}

model Transaction {
  id             String           @id @default(cuid())
  workspaceId    String
  accountId      String
  importFileId   String?
  categoryId     String?
  reviewStatus   ReviewStatus     @default(suggested)
  parserConfidence Int             @default(0)
  categoryConfidence Int           @default(0)
  accountMatchConfidence Int       @default(0)
  duplicateConfidence Int          @default(0)
  transferConfidence Int           @default(0)
  rawPayload     Json?
  normalizedPayload Json?
  learnedRuleIdsApplied Json?
  date           DateTime
  amount         Decimal          @db.Decimal(18, 2)
  currency       String           @default("PHP")
  type           TransactionType
  merchantRaw    String
  merchantClean  String?
  description    String?
  isTransfer     Boolean          @default(false)
  isExcluded     Boolean          @default(false)
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account        Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  importFile     ImportFile?      @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  category       Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  trainingSignals TrainingSignal[]

  @@index([workspaceId])
  @@index([accountId])
  @@index([importFileId])
  @@index([categoryId])
  @@index([reviewStatus])
  @@index([date])
}

model ImportFile {
  id            String           @id @default(cuid())
  workspaceId   String
  accountId     String?
  fileName      String
  fileType      String
  storageKey    String
  status        ImportFileStatus @default(processing)
  parsedRowsCount Int            @default(0)
  confirmedTransactionsCount Int @default(0)
  confirmedAt   DateTime?
  uploadedAt    DateTime         @default(now())
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account       Account?         @relation(fields: [accountId], references: [id], onDelete: SetNull)
  parsedRows    ParsedTransaction[]
  transactions  Transaction[]
  trainingSignals TrainingSignal[]
  statementCheckpoint AccountStatementCheckpoint?

  @@index([workspaceId])
  @@index([accountId])
  @@index([status])
}

model AccountStatementCheckpoint {
  id                   String                  @id @default(cuid())
  workspaceId          String
  accountId            String?
  importFileId         String?                 @unique
  statementStartDate   DateTime?
  statementEndDate     DateTime?
  openingBalance       Decimal?                @db.Decimal(18, 2)
  endingBalance        Decimal?                @db.Decimal(18, 2)
  status               StatementCheckpointStatus @default(pending)
  mismatchReason       String?
  sourceMetadata       Json?
  rowCount             Int                     @default(0)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  workspace            Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account              Account?                @relation(fields: [accountId], references: [id], onDelete: SetNull)
  importFile           ImportFile?             @relation(fields: [importFileId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([accountId])
  @@index([importFileId])
  @@index([statementStartDate])
  @@index([statementEndDate])
  @@index([status])
}

model ParsedTransaction {
  id             String      @id @default(cuid())
  importFileId   String
  workspaceId    String
  institution    String?
  accountNumber  String?
  accountName    String?
  date           DateTime?
  amount         Decimal?    @db.Decimal(18, 2)
  merchantRaw    String?
  merchantClean  String?
  type           TransactionType?
  categoryName   String?
  confidence     Int         @default(0)
  categoryReason String?
  parserVersion  String      @default("v1")
  statementFingerprint String?
  rawPayload     Json?
  createdAt      DateTime    @default(now())
  importFile     ImportFile   @relation(fields: [importFileId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([importFileId])
  @@index([statementFingerprint])
}

model StatementTemplate {
  id            String   @id @default(cuid())
  workspaceId   String
  fingerprint   String
  fileType      String?
  institution   String?
  accountNumber String?
  accountName   String?
  parserVersion String   @default("v1")
  parserConfig  Json?
  exampleCount  Int      @default(1)
  successCount  Int      @default(1)
  failureCount  Int      @default(0)
  lastSeenAt    DateTime @default(now())
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, fingerprint])
  @@index([workspaceId])
}

model GoalSetting {
  id             String   @id @default(cuid())
  userId         String
  primaryGoal    String?
  targetAmount   Decimal? @db.Decimal(18, 2)
  source         String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model MerchantRule {
  id             String   @id @default(cuid())
  workspaceId    String
  merchantKey    String
  merchantPattern String?
  normalizedName String
  categoryId     String?
  categoryName   String?
  source         String   @default("manual")
  confidence     Int      @default(100)
  timesConfirmed Int      @default(1)
  lastUsedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category       Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, merchantKey])
  @@index([workspaceId])
  @@index([merchantKey])
}

model AccountRule {
  id             String    @id @default(cuid())
  workspaceId    String
  accountId      String?
  ruleKey        String
  accountName    String
  institution    String?
  accountType    AccountType
  source         String    @default("manual")
  confidence     Int       @default(100)
  timesConfirmed Int       @default(1)
  lastUsedAt     DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account        Account?   @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, ruleKey])
  @@index([workspaceId])
  @@index([accountId])
  @@index([ruleKey])
}

model TrainingSignal {
  id            String               @id @default(cuid())
  workspaceId   String
  transactionId String?
  importFileId  String?
  source        TrainingSignalSource
  merchantKey   String
  dedupeKey     String
  merchantTokens Json?
  categoryId    String
  categoryName  String?
  type          TransactionType
  confidence    Int                  @default(100)
  notes         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transaction   Transaction?         @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  importFile    ImportFile?          @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  category      Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([transactionId])
  @@index([importFileId])
  @@index([merchantKey])
  @@unique([workspaceId, dedupeKey])
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorUserId String
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([actorUserId])
}
