generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceType {
  personal
  shared
  business
}

enum AccountType {
  bank
  wallet
  credit_card
  cash
  investment
  loan
  mortgage
  line_of_credit
  receivable
  payable
  bnpl
  prepaid
  insurance
  other
}

enum TransactionType {
  income
  expense
  transfer
}

enum ReviewStatus {
  pending_review
  suggested
  confirmed
  edited
  rejected
  duplicate_skipped
}

enum ImportFileStatus {
  processing
  done
  failed
  deleted
}

enum StatementCheckpointStatus {
  pending
  reconciled
  mismatch
}

enum CommitmentKind {
  planned_payment
  debt
  receivable
  reminder
}

enum CommitmentRecurrence {
  once
  weekly
  biweekly
  monthly
  quarterly
  annual
}

enum CommitmentStatus {
  active
  paused
  resolved
}

enum TrainingSignalSource {
  import_confirmation
  manual_recategorization
  training_upload
  manual_transaction_creation
}

enum PlanTier {
  free
  pro
}

enum BillingProvider {
  paypal
}

enum BillingInterval {
  monthly
  annual
}

enum SplitBillSourceType {
  manual
  receipt
}

enum BillingSubscriptionStatus {
  approval_pending
  active
  cancelled
  suspended
  expired
  unknown
}

enum BrankasStatementSessionStatus {
  initiated
  pending
  completed
  failed
  cancelled
  purged
  notified
  received
}

enum FinancialExperienceLevel {
  beginner
  comfortable
  advanced
}

enum ContactInquiryStatus {
  open
  in_progress
  responded
  closed
}

model User {
  id                       String                    @id @default(cuid())
  clerkUserId              String                    @unique
  email                    String                    @unique
  firstName                String?
  lastName                 String?
  verified                 Boolean                   @default(false)
  environment              String                    @default("production")
  planTier                 PlanTier                  @default(free)
  planTierLocked           Boolean                   @default(false)
  accountLimit             Int?
  monthlyUploadLimit       Int?
  transactionLimit         Int?
  financialExperience      FinancialExperienceLevel? @default(beginner)
  primaryGoal              String?
  goalTargetAmount         Decimal?                  @db.Decimal(18, 2)
  goalTargetSource         String?
  goalPlan                 Json?
  onboardingCompletedAt    DateTime?
  dataWipedAt              DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  workspaces               Workspace[]
  goalSettings             GoalSetting[]
  splitBillGroups          SplitBillGroup[]
  splitBillPeople          SplitBillPerson[]
  splitBills               SplitBill[]
  billingSubscription      BillingSubscription?
  billingEvents            BillingEvent[]
  brankasStatementSessions BrankasStatementSession[]
  appErrorLogs             AppErrorLog[]
}

model BillingSubscription {
  id                     String                    @id @default(cuid())
  userId                 String                    @unique
  provider               BillingProvider           @default(paypal)
  providerSubscriptionId String?                   @unique
  providerPlanId         String?
  status                 BillingSubscriptionStatus @default(unknown)
  planTier               PlanTier                  @default(free)
  interval               BillingInterval?
  pendingPlanId          String?
  pendingInterval        BillingInterval?
  currentPeriodEnd       DateTime?
  nextBillingTime        DateTime?
  cancelledAt            DateTime?
  approvedAt             DateTime?
  lastEventType          String?
  lastSyncedAt           DateTime?
  rawPayload             Json?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  user                   User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([providerSubscriptionId])
  @@index([providerPlanId])
  @@index([status])
}

model BillingEvent {
  id              String          @id @default(cuid())
  provider        BillingProvider @default(paypal)
  providerEventId String?         @unique
  eventType       String
  subscriptionId  String?
  userId          String?
  status          String?
  rawPayload      Json
  processedAt     DateTime?
  createdAt       DateTime        @default(now())
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@index([userId])
  @@index([eventType])
}

model BrankasStatementSession {
  id                      String                              @id @default(cuid())
  workspaceId             String
  userId                  String?
  externalId              String                              @unique
  statementId             String?                             @unique
  requestId               String?
  country                 String                              @default("PH")
  bankCodes               Json
  status                  BrankasStatementSessionStatus       @default(initiated)
  redirectUri             String?
  appRedirectUri          String
  appRedirectErrorUri     String?
  rawRequest              Json
  rawResponse             Json?
  lastNotificationStatus  String?
  lastNotificationPayload Json?
  lastNotificationAt      DateTime?
  createdAt               DateTime                            @default(now())
  updatedAt               DateTime                            @updatedAt
  workspace               Workspace                           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                    User?                               @relation(fields: [userId], references: [id], onDelete: SetNull)
  notifications           BrankasStatementNotificationEvent[]

  @@index([workspaceId])
  @@index([userId])
  @@index([statementId])
  @@index([requestId])
  @@index([status])
}

model BrankasStatementNotificationEvent {
  id                      String                   @id @default(cuid())
  brankasSessionId        String?
  statementId             String?
  notificationId          String?
  statementStatus         String?
  url                     String?
  payload                 Json
  httpStatus              String?
  httpResponse            String?
  error                   String?
  sentAt                  DateTime?
  createdAt               DateTime                 @default(now())
  brankasStatementSession BrankasStatementSession? @relation(fields: [brankasSessionId], references: [id], onDelete: SetNull)

  @@index([brankasSessionId])
  @@index([statementId])
  @@index([notificationId])
  @@index([statementStatus])
}

model AppErrorLog {
  id           String   @id @default(cuid())
  message      String
  name         String?
  stack        String?
  source       String
  route        String?
  url          String?
  method       String?
  statusCode   Int?
  buildId      String
  deploymentId String?
  environment  String
  userAgent    String?
  clerkUserId  String?
  userId       String?
  workspaceId  String?
  metadata     Json?
  occurredAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([buildId])
  @@index([environment])
  @@index([source])
  @@index([userId])
}

model ContactInquiry {
  id                String               @id @default(cuid())
  name              String
  email             String
  message           String
  attachment        Json?
  sourcePage        String?
  userAgent         String?
  status            ContactInquiryStatus @default(open)
  adminReplySubject String?
  adminReplyBody    String?
  adminReplyAt      DateTime?
  adminReplyBy      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
}

model Workspace {
  id                       String                       @id @default(cuid())
  userId                   String
  name                     String
  type                     WorkspaceType                @default(personal)
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt
  user                     User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts                 Account[]
  categories               Category[]
  transactions             Transaction[]
  importFiles              ImportFile[]
  documentImports          DocumentImport[]
  statementCheckpoints     AccountStatementCheckpoint[]
  financialCommitments     FinancialCommitment[]
  auditLogs                AuditLog[]
  statementTemplates       StatementTemplate[]
  merchantRules            MerchantRule[]
  accountRules             AccountRule[]
  trainingSignals          TrainingSignal[]
  dataQaRuns               DataQaRun[]
  dataQaFindings           DataQaFinding[]
  brankasStatementSessions BrankasStatementSession[]
  receiptDocuments         ReceiptDocument[]
  investmentSnapshots      InvestmentSnapshot[]
  investmentHoldings       InvestmentHolding[]
  recurringPatterns        RecurringPattern[]

  @@index([userId])
}

model Account {
  id                      String                       @id @default(cuid())
  workspaceId             String
  name                    String
  institution             String?
  accountNumber           String?
  investmentSubtype       String?
  investmentSymbol        String?
  investmentQuantity      Decimal?                     @db.Decimal(18, 8)
  investmentCostBasis     Decimal?                     @db.Decimal(18, 2)
  investmentPrincipal     Decimal?                     @db.Decimal(18, 2)
  investmentStartDate     DateTime?
  investmentMaturityDate  DateTime?
  investmentInterestRate  Decimal?                     @db.Decimal(9, 4)
  investmentMaturityValue Decimal?                     @db.Decimal(18, 2)
  type                    AccountType                  @default(bank)
  currency                String                       @default("PHP")
  source                  String                       @default("upload")
  balance                 Decimal?                     @db.Decimal(18, 2)
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  workspace               Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions            Transaction[]
  importFiles             ImportFile[]
  documentImports         DocumentImport[]
  statementCheckpoints    AccountStatementCheckpoint[]
  financialCommitments    FinancialCommitment[]
  accountRules            AccountRule[]
  investmentPurchases     InvestmentPurchase[]
  investmentDividends     InvestmentDividend[]
  receiptDocuments        ReceiptDocument[]
  investmentSnapshots     InvestmentSnapshot[]
  investmentHoldings      InvestmentHolding[]
  recurringPatterns       RecurringPattern[]

  @@index([workspaceId])
}

model InvestmentPurchase {
  id          String   @id @default(cuid())
  accountId   String
  purchasedAt DateTime
  quantity    Decimal? @db.Decimal(18, 8)
  totalCost   Decimal? @db.Decimal(18, 2)
  currency    String   @default("PHP")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([purchasedAt])
}

model InvestmentDividend {
  id        String   @id @default(cuid())
  accountId String
  paidAt    DateTime
  amount    Decimal? @db.Decimal(18, 2)
  currency  String   @default("PHP")
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([paidAt])
}

model Category {
  id               String           @id @default(cuid())
  workspaceId      String
  name             String
  type             TransactionType
  parentCategoryId String?
  isSystem         Boolean          @default(true)
  isArchived       Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  trainingSignals  TrainingSignal[]
  merchantRules    MerchantRule[]

  @@index([workspaceId])
}

model Transaction {
  id                     String                @id @default(cuid())
  workspaceId            String
  accountId              String
  importFileId           String?
  categoryId             String?
  reviewStatus           ReviewStatus          @default(suggested)
  parserConfidence       Int                   @default(0)
  categoryConfidence     Int                   @default(0)
  accountMatchConfidence Int                   @default(0)
  duplicateConfidence    Int                   @default(0)
  transferConfidence     Int                   @default(0)
  rawPayload             Json?
  normalizedPayload      Json?
  learnedRuleIdsApplied  Json?
  date                   DateTime
  amount                 Decimal               @db.Decimal(18, 2)
  currency               String                @default("PHP")
  type                   TransactionType
  merchantRaw            String
  merchantClean          String?
  description            String?
  isTransfer             Boolean               @default(false)
  isExcluded             Boolean               @default(false)
  deletedAt              DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  workspace              Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account                Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  financialCommitments   FinancialCommitment[]
  importFile             ImportFile?           @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  category               Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  trainingSignals        TrainingSignal[]
  dataQaFindings         DataQaFinding[]
  receiptDocument        ReceiptDocument?

  @@index([workspaceId])
  @@index([accountId])
  @@index([importFileId])
  @@index([categoryId])
  @@index([reviewStatus])
  @@index([deletedAt])
  @@index([date])
}

model ImportFile {
  id                         String                      @id @default(cuid())
  workspaceId                String
  accountId                  String?
  fileName                   String
  fileType                   String
  storageKey                 String
  status                     ImportFileStatus            @default(processing)
  processingPhase            String?
  processingMessage          String?
  processingAttempt          Int                         @default(0)
  processingTargetScore      Int?
  processingCurrentScore     Int?
  parsedRowsCount            Int                         @default(0)
  confirmedTransactionsCount Int                         @default(0)
  confirmedAt                DateTime?
  uploadedAt                 DateTime                    @default(now())
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  workspace                  Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account                    Account?                    @relation(fields: [accountId], references: [id], onDelete: SetNull)
  documentImport             DocumentImport?
  parsedRows                 ParsedTransaction[]
  transactions               Transaction[]
  trainingSignals            TrainingSignal[]
  statementCheckpoint        AccountStatementCheckpoint?
  dataQaRuns                 DataQaRun[]
  dataQaFindings             DataQaFinding[]

  @@index([workspaceId])
  @@index([accountId])
  @@index([status])
}

model DocumentImport {
  id                 String               @id @default(cuid())
  workspaceId        String
  importFileId       String?              @unique
  accountId          String?
  documentFamily     String
  documentSubtype    String?
  institution        String?
  accountName        String?
  accountNumber      String?
  currency           String               @default("PHP")
  pageCount          Int                  @default(0)
  confidence         Int                  @default(0)
  sourceMetadata     Json?
  rawPayload         Json?
  extractedPayload   Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  workspace          Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importFile         ImportFile?          @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  account            Account?             @relation(fields: [accountId], references: [id], onDelete: SetNull)
  pages              DocumentImportPage[]
  receiptDocument    ReceiptDocument?
  investmentSnapshot InvestmentSnapshot?
  investmentHoldings InvestmentHolding[]
  recurringPatterns  RecurringPattern[]

  @@index([workspaceId])
  @@index([accountId])
  @@index([documentFamily])
  @@index([importFileId])
}

model DocumentImportPage {
  id               String         @id @default(cuid())
  documentImportId String
  pageNumber       Int
  imageName        String?
  pageType         String?
  visibleTitle     String?
  visibleDate      String?
  visibleCurrency  String?
  rawOcrText       String?        @db.Text
  layoutNotes      String?        @db.Text
  confidence       Int            @default(0)
  rawPayload       Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  documentImport   DocumentImport @relation(fields: [documentImportId], references: [id], onDelete: Cascade)

  @@unique([documentImportId, pageNumber])
  @@index([documentImportId])
  @@index([pageType])
}

model AccountStatementCheckpoint {
  id                   String                    @id @default(cuid())
  workspaceId          String
  accountId            String?
  importFileId         String?                   @unique
  statementStartDate   DateTime?
  statementEndDate     DateTime?
  openingBalance       Decimal?                  @db.Decimal(18, 2)
  endingBalance        Decimal?                  @db.Decimal(18, 2)
  status               StatementCheckpointStatus @default(pending)
  mismatchReason       String?
  sourceMetadata       Json?
  rowCount             Int                       @default(0)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  workspace            Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account              Account?                  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  importFile           ImportFile?               @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  financialCommitments FinancialCommitment[]

  @@index([workspaceId])
  @@index([accountId])
  @@index([importFileId])
  @@index([statementStartDate])
  @@index([statementEndDate])
  @@index([status])
}

model ReceiptDocument {
  id               String          @id @default(cuid())
  workspaceId      String
  documentImportId String?         @unique
  accountId        String?
  transactionId    String?         @unique
  merchantRaw      String?
  merchantClean    String?
  transactionDate  DateTime?
  transactionTime  String?
  currency         String          @default("PHP")
  subtotal         Decimal?        @db.Decimal(18, 2)
  tax              Decimal?        @db.Decimal(18, 2)
  total            Decimal?        @db.Decimal(18, 2)
  paymentMethod    String?
  accountMatch     Json?
  confidence       Int             @default(0)
  rawPayload       Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documentImport   DocumentImport? @relation(fields: [documentImportId], references: [id], onDelete: SetNull)
  account          Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  transaction      Transaction?    @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([accountId])
  @@index([transactionId])
}

model InvestmentSnapshot {
  id               String              @id @default(cuid())
  workspaceId      String
  documentImportId String?             @unique
  accountId        String?
  snapshotDate     DateTime?
  portfolioName    String?
  currency         String              @default("PHP")
  totalValue       Decimal?            @db.Decimal(18, 2)
  costBasis        Decimal?            @db.Decimal(18, 2)
  gainLossValue    Decimal?            @db.Decimal(18, 2)
  gainLossPercent  Decimal?            @db.Decimal(18, 8)
  confidence       Int                 @default(0)
  rawPayload       Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  workspace        Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documentImport   DocumentImport?     @relation(fields: [documentImportId], references: [id], onDelete: SetNull)
  account          Account?            @relation(fields: [accountId], references: [id], onDelete: SetNull)
  holdings         InvestmentHolding[]

  @@index([workspaceId])
  @@index([accountId])
  @@index([snapshotDate])
}

model InvestmentHolding {
  id                   String             @id @default(cuid())
  workspaceId          String
  investmentSnapshotId String
  documentImportId     String?
  accountId            String?
  rowIndex             Int?
  assetName            String
  assetSymbol          String?
  assetType            String?
  quantity             Decimal?           @db.Decimal(18, 8)
  unitPrice            Decimal?           @db.Decimal(18, 8)
  costBasis            Decimal?           @db.Decimal(18, 2)
  marketValue          Decimal?           @db.Decimal(18, 2)
  currentValue         Decimal?           @db.Decimal(18, 2)
  gainLossValue        Decimal?           @db.Decimal(18, 2)
  gainLossPercent      Decimal?           @db.Decimal(18, 8)
  currency             String             @default("PHP")
  status               String?
  confidence           Int                @default(0)
  rawPayload           Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  workspace            Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  investmentSnapshot   InvestmentSnapshot @relation(fields: [investmentSnapshotId], references: [id], onDelete: Cascade)
  documentImport       DocumentImport?    @relation(fields: [documentImportId], references: [id], onDelete: SetNull)
  account              Account?           @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([investmentSnapshotId])
  @@index([documentImportId])
  @@index([accountId])
  @@index([assetSymbol])
}

model RecurringPattern {
  id               String                @id @default(cuid())
  workspaceId      String
  documentImportId String?
  accountId        String?
  merchantRaw      String
  merchantClean    String?
  amount           Decimal?              @db.Decimal(18, 2)
  currency         String                @default("PHP")
  frequency        CommitmentRecurrence?
  firstSeenDate    DateTime?
  lastSeenDate     DateTime?
  nextExpectedDate DateTime?
  transactionCount Int                   @default(1)
  confidence       Int                   @default(0)
  rawPayload       Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  workspace        Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documentImport   DocumentImport?       @relation(fields: [documentImportId], references: [id], onDelete: SetNull)
  account          Account?              @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([accountId])
  @@index([documentImportId])
  @@index([nextExpectedDate])
  @@index([frequency])
}

model ParsedTransaction {
  id                   String           @id @default(cuid())
  importFileId         String
  workspaceId          String
  institution          String?
  accountNumber        String?
  accountName          String?
  date                 DateTime?
  amount               Decimal?         @db.Decimal(18, 2)
  currency             String           @default("PHP")
  merchantRaw          String?
  merchantClean        String?
  type                 TransactionType?
  categoryName         String?
  confidence           Int              @default(0)
  categoryReason       String?
  parserVersion        String           @default("v1")
  statementFingerprint String?
  rawPayload           Json?
  createdAt            DateTime         @default(now())
  importFile           ImportFile       @relation(fields: [importFileId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([importFileId])
  @@index([statementFingerprint])
}

model StatementTemplate {
  id            String    @id @default(cuid())
  workspaceId   String
  fingerprint   String
  fileType      String?
  institution   String?
  accountNumber String?
  accountName   String?
  parserVersion String    @default("v1")
  parserConfig  Json?
  exampleCount  Int       @default(1)
  successCount  Int       @default(1)
  failureCount  Int       @default(0)
  lastSeenAt    DateTime  @default(now())
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, fingerprint])
  @@index([workspaceId])
}

model GoalSetting {
  id           String   @id @default(cuid())
  userId       String
  primaryGoal  String?
  targetAmount Decimal? @db.Decimal(18, 2)
  source       String?
  goalPlan     Json?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model SplitBillGroup {
  id        String                @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  members   SplitBillGroupMember[]
  bills     SplitBill[]

  @@index([userId])
}

model SplitBillPerson {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SplitBillGroupMember {
  id        String           @id @default(cuid())
  groupId   String
  name      String
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  group     SplitBillGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model SplitBill {
  id                  String                 @id @default(cuid())
  userId              String
  groupId             String?
  title               String
  note                String?
  billDate            DateTime
  currency            String                 @default("PHP")
  sourceType          SplitBillSourceType    @default(manual)
  merchantName        String?
  receiptFileName     String?
  receiptMimeType     String?
  receiptText         String?                @db.Text
  receiptConfidence   Int                    @default(0)
  subtotal            Decimal?               @db.Decimal(18, 2)
  tax                 Decimal?               @db.Decimal(18, 2)
  tip                 Decimal?               @db.Decimal(18, 2)
  discount            Decimal?               @db.Decimal(18, 2)
  total               Decimal?               @db.Decimal(18, 2)
  rawPayload          Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  user                User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group               SplitBillGroup?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  participants        SplitBillParticipant[]
  items               SplitBillItem[]
  payments            SplitBillPayment[]

  @@index([userId])
  @@index([groupId])
  @@index([billDate])
  @@index([sourceType])
}

model SplitBillParticipant {
  id        String              @id @default(cuid())
  billId    String
  name      String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  bill      SplitBill           @relation(fields: [billId], references: [id], onDelete: Cascade)
  itemLinks SplitBillItemParticipant[]
  payments  SplitBillPayment[]

  @@index([billId])
}

model SplitBillItem {
  id        String                    @id @default(cuid())
  billId    String
  description String
  amount    Decimal                   @db.Decimal(18, 2)
  sortOrder Int                       @default(0)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  bill      SplitBill                 @relation(fields: [billId], references: [id], onDelete: Cascade)
  participants SplitBillItemParticipant[]

  @@index([billId])
}

model SplitBillItemParticipant {
  id            String              @id @default(cuid())
  itemId        String
  participantId String
  createdAt     DateTime            @default(now())
  item          SplitBillItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  participant   SplitBillParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([itemId, participantId])
  @@index([itemId])
  @@index([participantId])
}

model SplitBillPayment {
  id            String                @id @default(cuid())
  billId        String
  participantId String
  amount        Decimal               @db.Decimal(18, 2)
  note          String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  bill          SplitBill             @relation(fields: [billId], references: [id], onDelete: Cascade)
  participant   SplitBillParticipant   @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([participantId])
}

model FinancialCommitment {
  id                    String                      @id @default(cuid())
  workspaceId           String
  kind                  CommitmentKind
  title                 String
  counterparty          String?
  amount                Decimal?                    @db.Decimal(18, 2)
  currency              String                      @default("PHP")
  dueDate               DateTime?
  recurrence            CommitmentRecurrence        @default(once)
  nextDueDate           DateTime?
  notes                 String?
  accountId             String?
  transactionId         String?
  statementCheckpointId String?
  status                CommitmentStatus            @default(active)
  source                String                      @default("manual")
  confidence            Int                         @default(100)
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  workspace             Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account               Account?                    @relation(fields: [accountId], references: [id], onDelete: SetNull)
  transaction           Transaction?                @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  statementCheckpoint   AccountStatementCheckpoint? @relation(fields: [statementCheckpointId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([kind])
  @@index([status])
  @@index([dueDate])
  @@index([nextDueDate])
  @@index([accountId])
  @@index([transactionId])
  @@index([statementCheckpointId])
}

model DataQaConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  body      String   @db.Text
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model MerchantRule {
  id              String    @id @default(cuid())
  workspaceId     String
  merchantKey     String
  merchantPattern String?
  normalizedName  String
  categoryId      String?
  categoryName    String?
  source          String    @default("manual")
  confidence      Int       @default(100)
  timesConfirmed  Int       @default(1)
  lastUsedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, merchantKey])
  @@index([workspaceId])
  @@index([merchantKey])
}

model AccountRule {
  id             String      @id @default(cuid())
  workspaceId    String
  accountId      String?
  ruleKey        String
  accountName    String
  institution    String?
  accountType    AccountType
  source         String      @default("manual")
  confidence     Int         @default(100)
  timesConfirmed Int         @default(1)
  lastUsedAt     DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  workspace      Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account        Account?    @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, ruleKey])
  @@index([workspaceId])
  @@index([accountId])
  @@index([ruleKey])
}

model TrainingSignal {
  id             String               @id @default(cuid())
  workspaceId    String
  transactionId  String?
  importFileId   String?
  source         TrainingSignalSource
  merchantKey    String
  dedupeKey      String
  merchantTokens Json?
  categoryId     String
  categoryName   String?
  type           TransactionType
  confidence     Int                  @default(100)
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transaction    Transaction?         @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  importFile     ImportFile?          @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  category       Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, dedupeKey])
  @@index([workspaceId])
  @@index([transactionId])
  @@index([importFileId])
  @@index([merchantKey])
}

model DataQaRun {
  id                      String          @id @default(cuid())
  workspaceId             String
  importFileId            String?
  source                  String
  stage                   String?
  status                  String          @default("completed")
  parserVersion           String?
  parserDurationMs        Int?
  totalDurationMs         Int?
  score                   Int             @default(0)
  findingCount            Int             @default(0)
  criticalCount           Int             @default(0)
  feedbackPayload         Json?
  manualFeedback          String?
  manualFeedbackUpdatedAt DateTime?
  manualFeedbackAuthorId  String?
  fieldReviewPayload      Json?
  fieldReviewUpdatedAt    DateTime?
  fieldReviewAuthorId     String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  workspace               Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importFile              ImportFile?     @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  findings                DataQaFinding[]

  @@index([workspaceId])
  @@index([importFileId])
  @@index([source])
  @@index([status])
}

model DataQaFinding {
  id            String       @id @default(cuid())
  workspaceId   String
  dataQaRunId   String
  importFileId  String?
  transactionId String?
  code          String
  severity      String
  field         String?
  message       String
  observedValue Json?
  expectedValue Json?
  suggestion    String?
  confidence    Int          @default(0)
  metadata      Json?
  createdAt     DateTime     @default(now())
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dataQaRun     DataQaRun    @relation(fields: [dataQaRunId], references: [id], onDelete: Cascade)
  importFile    ImportFile?  @relation(fields: [importFileId], references: [id], onDelete: SetNull)
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([dataQaRunId])
  @@index([importFileId])
  @@index([transactionId])
  @@index([code])
  @@index([severity])
}

model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  actorUserId String
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([actorUserId])
}
